    <iconUrl>https://raw.githubusercontent.com/aryanpnd/git-wtm/main/assets/logo.svg</iconUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>A modern, interactive TUI for managing Git worktrees and branches. No more memorizing commands — just navigate, search, and act.</description>
